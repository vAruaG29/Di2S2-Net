# ============================================================
# SVAMITVA — GitHub holds CODE ONLY.
# All heavy assets (rasters, COGs, checkpoints, results, portal
# library) live on Google Drive — see README "Getting the data".
# These rules keep data out even if the folders get populated
# locally after extracting the Drive archive into the repo root.
# ============================================================

# --- Heavy input & derived data (Google Drive) ---
data/
cog/
tiles/
masks/
dataset/
portal_workspace/

# --- Results: keep only the tiny evaluation CSVs ---
outputs/*
!outputs/evaluation/
outputs/evaluation/*.tif
outputs/evaluation/*.gpkg

# --- Model weights (Google Drive) ---
pretrained/*.ckpt
checkpoints/
checkpoints_2val/
logs/
logs_2val/

# --- Regenerated by setup_env.sh / the pipeline ---
models/dinov3/
portal/frontend/node_modules/
portal/frontend/dist/
portal/frontend/.vite/
**/__pycache__/
*.pyc
*.pyo

# --- Runtime / editor / OS cruft ---
visualizations/
*.tmp
*.tmp.*
.DS_Store
._*
.env
.venv/
*.log
